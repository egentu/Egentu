{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/BingSiteAuth.xml",
      "dest": "/BingSiteAuth.xml"
    },
    {
      "src": "/google4b7cb44608b330f8.html",
      "dest": "/google4b7cb44608b330f8.html"
    },

  ]
}