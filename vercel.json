{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
    "src": "/(robots.txt|sitemap.xml|BingSiteAuth.xml|google4b7cb44608b330f8.html)",
    "dest": "/$1"
    },

    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}